check_info <- data.frame(
  file = files,
  n_elements = NA,
  lengths_ok = NA
)

for (i in seq_along(files)) {
  test <- tryCatch(readRDS(files[i]), error = function(e) NULL)
  
  if (is.null(test)) {
    check_info$n_elements[i] <- NA
    check_info$lengths_ok[i] <- FALSE
    next
  }
  
  check_info$n_elements[i] <- length(test)
  lens <- sapply(test, length)
  check_info$lengths_ok[i] <- all(lens == 303*360)
}

# Show any problem files
check_info[!check_info$lengths_ok | check_info$n_elements != 11, ]
